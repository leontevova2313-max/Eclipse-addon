{
  "schemaVersion": 1,
  "id": "eclipse",
  "version": "${version}",
  "name": "Eclipse",
  "description": "A polished Meteor Client addon for visuals, menu customization, camera control, and lightweight utilities.",
  "authors": ["Rud"],
  "environment": "client",
  "custom": {
    "meteor-client:color": "209 107 255"
  },

  "entrypoints": {
    "meteor": [
      "eclipse.Eclipse"
    ]
  },

  "mixins": [
    "eclipse.mixins.json"
  ],

  "depends": {
    "fabricloader": "*",
    "minecraft": "*",
    "meteor-client": "*"
  }
}
